# rpolycallrc - read-only R runtime overrides for libpolycall
#
# This file uses the SHARED polycall schema (src/config/polycall_config_schema.c).
# It introduces no new keys or parser: the R adapter passes this path to
# the core via the FFI boundary. Values here override polycallrc for R.

log_level=info
max_connections=1000
network_timeout=5000
tls_enabled=false
